#!/usr/bin/env bash
# olcRTC server launcher.
#
# Reads /etc/olcrtc/env (already loaded by systemd into the process
# environment via EnvironmentFile=) and translates it into the right
# command-line flags for the olcrtc binary. This indirection is necessary
# because systemd's ExecStart= does not support conditional arguments.
#
# Recognised environment variables:
#   OLCRTC_PROVIDER          required: telemost | jazz | wb_stream
#   OLCRTC_ROOM_ID           required: room ID (for jazz/wb_stream "any" auto-creates)
#   OLCRTC_KEY               required: 64-char hex encryption key
#   OLCRTC_DNS               optional: DNS resolver (default 1.1.1.1:53)
#   OLCRTC_DEBUG             optional: set to 1 to enable -debug verbose logging
#   OLCRTC_SOCKS_PROXY       optional: SOCKS5 proxy used for outbound traffic.
#                                       Accepted forms:
#                                         host:port
#                                         user:pass@host:port    (RFC 1929)
#                                         socks5://[user:pass@]host:port
#                                         socks5h://[user:pass@]host:port
#                                       Useful when the VPS's own IP is
#                                       blocked by wb_stream/jazz/telemost —
#                                       point this at a residential proxy.

set -euo pipefail

if [ -z "${OLCRTC_PROVIDER:-}" ] || [ -z "${OLCRTC_ROOM_ID:-}" ] || [ -z "${OLCRTC_KEY:-}" ]; then
    echo "olcrtc-launcher: missing required env (OLCRTC_PROVIDER / OLCRTC_ROOM_ID / OLCRTC_KEY)" >&2
    exit 64
fi

ARGS=(
    -mode srv
    -provider "$OLCRTC_PROVIDER"
    -id "$OLCRTC_ROOM_ID"
    -key "$OLCRTC_KEY"
    -dns "${OLCRTC_DNS:-1.1.1.1:53}"
)

if [ -n "${OLCRTC_DEBUG:-}" ] && [ "$OLCRTC_DEBUG" != "0" ] && [ "$OLCRTC_DEBUG" != "false" ]; then
    ARGS+=(-debug)
fi

if [ -n "${OLCRTC_SOCKS_PROXY:-}" ]; then
    proxy="$OLCRTC_SOCKS_PROXY"
    # Strip optional scheme prefix.
    proxy="${proxy#socks5://}"
    proxy="${proxy#socks5h://}"

    proxy_user=""
    proxy_pass=""
    if [[ "$proxy" == *"@"* ]]; then
        creds="${proxy%@*}"
        proxy="${proxy##*@}"
        if [[ "$creds" == *":"* ]]; then
            proxy_user="${creds%%:*}"
            proxy_pass="${creds#*:}"
        else
            proxy_user="$creds"
        fi
    fi

    if [[ "$proxy" != *":"* ]]; then
        echo "olcrtc-launcher: OLCRTC_SOCKS_PROXY must contain host:port (got '$proxy')" >&2
        exit 66
    fi
    proxy_host="${proxy%:*}"
    proxy_port="${proxy##*:}"
    if ! [[ "$proxy_port" =~ ^[0-9]+$ ]]; then
        echo "olcrtc-launcher: OLCRTC_SOCKS_PROXY port is not numeric ('$proxy_port')" >&2
        exit 67
    fi

    ARGS+=(-socks-proxy "$proxy_host" -socks-proxy-port "$proxy_port")
    if [ -n "$proxy_user" ]; then
        ARGS+=(-socks-proxy-user "$proxy_user")
    fi
    if [ -n "$proxy_pass" ]; then
        ARGS+=(-socks-proxy-pass "$proxy_pass")
    fi
fi

exec /usr/local/bin/olcrtc "${ARGS[@]}"
